NODE_ENV=development
PORT=3006

DB_HOST=localhost
DB_PORT=3306
DB_NAME=club_asistencia
DB_USER=root
DB_PASSWORD=123456
DB_DIALECT=mysql
DB_CONNECT_TIMEOUT_MS=8000
START_WITHOUT_DB=false

RUTA_SEGURA=https://api.rutasegura/co/v1/
INTEGRATIONIDMED=
INTEGRATIONIDRET=
BEARERMED=
BEARERRET=
EVALUACION_FONDO_PATH=assets/fondo.jpg
# Tamaño máximo de foto en informes (MB). Fotos de celular suelen superar 10 MB.
EVALUACION_FOTO_MAX_MB=20
EVALUACION_LOGO_PATH=assets/logo.png
EVALUACION_LOGO_MAEX_PATH=assets/logo.png

# Envío de informes por correo: ventana (fechas YYYY-MM-DD, hoy en America/Bogota). Vacío = sin límite en ese extremo.
# INFORME_ENVIO_HABILITADO=false desactiva el envío (403 en API y botón deshabilitado en front vía GET ventana-envio).
INFORME_ENVIO_HABILITADO=true
INFORME_ENVIO_DESDE=
INFORME_ENVIO_HASTA=

# Periodos de informes: mes de inscripción/evaluación a filtrar (1-12). Periodo 1 = ene_jul, periodo 2 = ago_dic.
INFORMES_PERIODO_1_MES=6
INFORMES_PERIODO_2_MES=11
# INFORMES_PERIODO_1_ETIQUETA=Junio
# INFORMES_PERIODO_2_ETIQUETA=Noviembre

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_SECURE=false

JWT_SECRET=cambiar_por_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d
APP_PUBLIC_URL=http://localhost:3006
# URL del sitio React (enlaces en correos de registro y recuperación)
FRONTEND_URL=http://localhost:5173
# Orígenes permitidos por CORS (separados por coma). Incluir el dominio del frontend en prod.
# Ej: CORS_ORIGINS=https://clubdeportivocsjv.com,https://www.clubdeportivocsjv.com
CORS_ORIGINS=
# Saltos de proxy de confianza para X-Forwarded-For (rate limit por IP real).
# Local: 0. Hostinger/nginx (producción): 1. Vacío = auto (1 en producción, 0 en dev).
TRUST_PROXY=
# Límites de peticiones. Subirlos si muchos usuarios comparten IP (WiFi colegio/NAT).
# /api cuenta por usuario (token) cuando hay sesión; login cuenta por IP.
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_API_MAX=2000
RATE_LIMIT_INTEGRACION_MAX=120
# Carpeta persistente para fotos/PDF de evaluaciones (fuera del release/deploy).
# En producción (Hostinger), apunta a una ruta en raíz del proyecto, por ejemplo:
# UPLOADS_DIR=/home/usuario/uploads_club
UPLOADS_DIR=

MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
# Debe coincidir con la URI registrada en Azure. Si usas :3006, el API reenvía ?code= al front (FRONTEND_URL).
MICROSOFT_REDIRECT_URI=http://localhost:3006/callback-microsoft

# Integración club (GET /api/integracion-club/:sede)
BEARERINS=

# Pool SMTP (opcional)
# EMAIL_POOL_MAX_CONNECTIONS=5
# EMAIL_POOL_MAX_MESSAGES=100

# Cola de envío de informes
# true = envío de informes solo a correos de padre, madre y responsable (requerido para POST .../enviar).
# EVALUACION_EMAIL_INCLUIR_CORREOS_FAMILIA=true
# EVALUACION_EMAIL_QUEUE_CONCURRENCY=3
# EVALUACION_EMAIL_QUEUE_POLL_MS=1200
# EVALUACION_EMAIL_QUEUE_IDLE_POLL_MS=6000
